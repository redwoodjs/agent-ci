{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "machinen",
  "main": "src/worker.tsx",
  "compatibility_date": "2025-11-23",
  "compatibility_flags": ["nodejs_compat"],
  "account_id": "1634a8e653b2ce7e0f7a23cca8cbd86a",

  "observability": {
    "enabled": true
  },

  "r2_buckets": [
    {
      "binding": "MACHINEN_BUCKET",
      "bucket_name": "machinen",
      "remote": true
    }
  ],
  "ai": {
    "binding": "AI",
    "remote": true
  },
  "vectorize": [
    {
      "binding": "VECTORIZE_INDEX",
      "index_name": "rag-index-v6",
      "remote": true
    },
    {
      "binding": "SUBJECT_INDEX",
      "index_name": "subject-index-v6",
      "remote": true
    },
    {
      "binding": "MOMENT_INDEX",
      "index_name": "moment-index-v6",
      "remote": true
    }
  ],

  "migrations": [
    {
      "tag": "v1",
      "new_classes": ["RealtimeDurableObject"],
      "new_sqlite_classes": ["Database"]
    },
    {
      "tag": "v2",
      "deleted_classes": []
    },
    {
      "tag": "v3",
      "new_sqlite_classes": ["CursorEventsDurableObject"]
    },
    {
      "tag": "v4",
      "new_sqlite_classes": ["GitHubRepoDurableObject"]
    },
    {
      "tag": "v5",
      "new_sqlite_classes": ["GitHubBackfillStateDO"]
    },
    {
      "tag": "v6",
      "new_sqlite_classes": ["EngineIndexingStateDO"]
    },
    {
      "tag": "v7",
      "new_sqlite_classes": ["DiscordBackfillStateDO"]
    },
    {
      "tag": "v8",
      "new_classes": ["DiscordWebhookBatcherDO"]
    },
    {
      "tag": "v9",
      "new_classes": ["DiscordGatewayDO"]
    },
    {
      "tag": "v10",
      "deleted_classes": ["DiscordGatewayDO"]
    },
    {
      "tag": "v11",
      "new_sqlite_classes": ["SubjectDO"]
    },
    {
      "tag": "v12",
      "new_sqlite_classes": ["MomentGraphDO"]
    }
  ],
  "durable_objects": {
    "bindings": [
      { "name": "REALTIME", "class_name": "RealtimeDurableObject" },
      { "name": "DB", "class_name": "Database" },
      { "name": "CURSOR_EVENTS", "class_name": "CursorEventsDurableObject" },
      { "name": "GITHUB_REPO", "class_name": "GitHubRepoDurableObject" },
      {
        "name": "GITHUB_BACKFILL_STATE",
        "class_name": "GitHubBackfillStateDO"
      },
      {
        "name": "ENGINE_INDEXING_STATE",
        "class_name": "EngineIndexingStateDO"
      },
      {
        "name": "DISCORD_BACKFILL_STATE",
        "class_name": "DiscordBackfillStateDO"
      },
      {
        "name": "SUBJECT_GRAPH_DO",
        "class_name": "SubjectDO"
      },
      {
        "name": "MOMENT_GRAPH_DO",
        "class_name": "MomentGraphDO"
      },
      {
        "name": "DISCORD_WEBHOOK_BATCHER",
        "class_name": "DiscordWebhookBatcherDO"
      }
    ]
  },
  "queues": {
    "producers": [
      {
        "queue": "github-scheduler-queue-prod",
        "binding": "SCHEDULER_QUEUE"
      },
      {
        "queue": "github-processor-queue-prod",
        "binding": "PROCESSOR_QUEUE"
      },
      {
        "queue": "engine-indexing-queue-prod",
        "binding": "ENGINE_INDEXING_QUEUE"
      },
      {
        "queue": "r2-file-update-queue-prod",
        "binding": "R2_FILE_UPDATE_QUEUE"
      },
      {
        "queue": "discord-scheduler-queue-prod",
        "binding": "DISCORD_SCHEDULER_QUEUE"
      },
      {
        "queue": "discord-processor-queue-prod",
        "binding": "DISCORD_PROCESSOR_QUEUE"
      },
      {
        "queue": "discord-gateway-events-queue-prod",
        "binding": "DISCORD_GATEWAY_EVENTS_QUEUE"
      },
      {
        "queue": "chunk-processing-queue-prod",
        "binding": "CHUNK_PROCESSING_QUEUE"
      }
    ],
    "consumers": [
      {
        "queue": "github-scheduler-queue-prod",
        "max_batch_size": 10,
        "max_batch_timeout": 30
      },
      {
        "queue": "github-processor-queue-prod",
        "max_batch_size": 100,
        "max_batch_timeout": 30,
        "dead_letter_queue": "github-processor-queue-prod-dlq",
