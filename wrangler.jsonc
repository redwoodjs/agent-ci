{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "machinen",
  "main": "src/worker.tsx",
  "compatibility_date": "2025-07-29",
  "compatibility_flags": ["nodejs_compat"],

  "containers": [
    {
      "name": "Sandbox",
      "image": "./Dockerfile",
      "class_name": "Sandbox",
      "max_instances": 1
    }
  ],
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["Sandbox", "Database", "PasskeyDurableObject"]
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "class_name": "Sandbox",
        "name": "Sandbox"
      },
      {
        "class_name": "Database",
        "name": "DATABASE"
      },
      {
        "name": "REALTIME_DURABLE_OBJECT",
        "class_name": "RealtimeDurableObject"
      }
    ]
  }
}
