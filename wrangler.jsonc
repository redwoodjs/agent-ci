{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "machinen",
  "main": "src/worker.tsx",
  "compatibility_date": "2025-07-29",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "containers": [
    {
      "name": "rwsdk",
      "image": "./Dockerfile",
      "class_name": "MachinenContainer",
      "max_instances": 5
    }
  ],
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["MachinenContainer"]
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "class_name": "MachinenContainer",
        "name": "CONTAINER"
      }
    ]
  }
}
