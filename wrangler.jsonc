{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "machinen",
  "main": "src/worker.tsx",
  "compatibility_date": "2025-09-25",
  "compatibility_flags": ["nodejs_compat"],
  "r2_buckets": [
    {
      "binding": "MACHINEN_CONTEXT_STREAM_BUCKET",
      "bucket_name": "machinen-context-stream",
      "remote": true
    },
    {
      "binding": "MACHINEN_BUCKET",
      "bucket_name": "machinen",
      "remote": true
    }
  ],
  "ai": {
    "binding": "AI",
    "remote": true
  },
  "containers": [
    {
      "name": "Sandbox",
      "image": "./Dockerfile",
      "class_name": "Sandbox",
      "max_instances": 1
    }
  ],
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["Sandbox", "Database", "ProcessLog"]
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "class_name": "Sandbox",
        "name": "Sandbox"
      },
      {
        "class_name": "Database",
        "name": "DATABASE"
      },
      {
        "name": "REALTIME_DURABLE_OBJECT",
        "class_name": "RealtimeDurableObject"
      }
    ]
  }
}
