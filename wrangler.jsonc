{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "machinen",
  "main": "src/worker.tsx",
  "compatibility_date": "2025-09-25",
  "compatibility_flags": ["nodejs_compat"],
  "r2_buckets": [
    {
      "binding": "MACHINEN_CONTEXT_STREAM_BUCKET",
      "bucket_name": "machinen-context-stream",
      "remote": true
    },
    {
      "binding": "MACHINEN_BUCKET",
      "bucket_name": "machinen",
      "remote": true
    }
  ],
  "ai": {
    "binding": "AI",
    "remote": true
  },

  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["Database", "ProcessLog", "RawDiscordDatabase"]
    },
    {
      "tag": "v2",
      "deleted_classes": ["Container"]
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "class_name": "Database",
        "name": "DATABASE"
      },
      {
        "class_name": "RawDiscordDatabase",
        "name": "RAW_DISCORD_DATABASE"
      },
      {
        "name": "REALTIME_DURABLE_OBJECT",
        "class_name": "RealtimeDurableObject"
      }
    ]
  }
}
