        "max_batch_size": 10,
        "max_batch_timeout": 30
      },
      {
        "queue": "discord-scheduler-queue-prod",
        "max_batch_size": 10,
        "max_batch_timeout": 30
      },
      {
        "queue": "discord-processor-queue-prod",
        "max_batch_size": 100,
        "max_batch_timeout": 30,
        "dead_letter_queue": "discord-processor-queue-prod-dlq",
        "max_retries": 3
      },
      {
        "queue": "discord-processor-queue-prod-dlq",
        "max_batch_size": 10,
        "max_batch_timeout": 30
      },
      {
        "queue": "discord-gateway-events-queue-prod",
        "max_batch_size": 100,
        "max_batch_timeout": 30,
        "dead_letter_queue": "discord-gateway-events-queue-prod-dlq",
        "max_retries": 3
      },
      {
        "queue": "discord-gateway-events-queue-prod-dlq",
        "max_batch_size": 10,
        "max_batch_timeout": 30
      },
      {
        "queue": "chunk-processing-queue-prod",
        "max_batch_size": 100,
        "max_batch_timeout": 30
      }
    ]
  },
  "vars": {
    "MOMENT_GRAPH_NAMESPACE_PREFIX": "prod-2025-12-19-20-04"
  },
