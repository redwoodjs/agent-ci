{
  "name": "@redwoodjs/ts-runner",
  "version": "0.7.0",
  "description": "TypeScript GitHub Actions step runner — no Docker, no .NET binary.",
  "keywords": [
    "ci",
    "github-actions",
    "local-runner",
    "runner",
    "typescript"
  ],
  "license": "FSL-1.1-MIT",
  "author": "",
  "repository": {
    "type": "git",
