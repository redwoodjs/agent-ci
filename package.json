{
  "name": "agent-ci-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "pnpm --include-workspace-root=false -r test",
    "check": "npm-run-all --parallel typecheck lint format:check compat:check parse:diff",
    "check:fix": "npm-run-all --parallel typecheck lint:fix format:fix",
    "compat:gen": "node scripts/gen-compatibility-md.mjs",
    "compat:check": "node scripts/gen-compatibility-md.mjs --check",
    "fixtures:check": "node scripts/fixtures-check.mjs",
    "typecheck": "pnpm -r run typecheck",
    "lint": "oxlint --deny-warnings",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:fix": "oxfmt",
    "format:check": "oxfmt --check",
    "rust:check": "cargo check --workspace --all-targets",
    "rust:clippy": "cargo clippy --workspace --all-targets -- -D warnings",
    "rust:fmt": "cargo fmt --all",
    "rust:fmt:check": "cargo fmt --all -- --check",
    "rust:test": "cargo test --workspace --all-targets",
    "golden:cli": "node scripts/golden-cli-rust.mjs",
    "rust:smoke:parity": "node scripts/rust-smoke-parity.mjs",
    "rust:perf": "node scripts/rust-performance.mjs",
    "smoke:bench": "node scripts/smoke-benchmark.mjs",
    "native:stage-packages": "node scripts/stage-native-package-bins.mjs",
    "agent-ci": "cd packages/dtu-github-actions && pnpm run build && cd ../cli && node src/cli.ts",
    "agent-ci-dev": "./scripts/agent-ci-dev.sh",
    "demo": "bash .docs/marketing/demo-recording/demo.sh",
    "parse:diff": "node scripts/diff-parse.ts",
    "ts-runner": "node packages/ts-runner/src/cli.ts",
    "start": "./scripts/run.sh",
    "prepare": "husky || true",
    "changeset": "changeset",
    "version": "node scripts/release-closes.mjs capture && changeset version && oxfmt",
    "release": "pnpm -r build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@nkzw/oxlint-config": "1.0.1",
    "@types/node": "^25.3.0",
    "@typescript/native-preview": "7.0.0-dev.20260219.1",
    "fallow": "^2.63.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "npm-run-all2": "8.0.4",
    "oxfmt": "0.33.0",
    "oxlint": "1.48.0",
    "vitest": "^4.1.0",
    "yaml": "^2.8.3"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,css,html}": [
      "oxfmt --check"
    ],
    "*.{js,ts,jsx,tsx}": [
      "oxlint --deny-warnings"
    ]
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.30.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ],
    "overrides": {
      "@babel/core@<=7.29.0": "7.29.6",
      "@grpc/grpc-js@>=1.14.0 <1.14.4": "1.14.4",
      "@protobufjs/utf8@<=1.1.0": "1.1.1",
      "basic-ftp@<=5.3.0": "5.3.1",
      "brace-expansion@>=4.0.0 <5.0.6": "5.0.6",
      "esbuild@>=0.27.3 <0.28.1": "0.28.1",
      "gray-matter>js-yaml": "3.15.0",
      "ip-address@<=10.1.0": "10.1.1",
      "js-yaml@>=4.0.0 <=4.1.1": "4.2.0",
      "kysely@>=0.26.0 <0.28.17": "0.28.17",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "postcss@<8.5.10": "8.5.10",
      "protobufjs@<7.6.3": "7.6.3",
      "qs@>=6.11.1 <=6.15.1": "6.15.2",
      "read-yaml-file>js-yaml": "3.15.0",
      "rwsdk>decompress": "npm:@xhmikosr/decompress@11.1.3",
      "serialize-javascript@<7.0.5": "7.0.5",
      "shell-quote@>=1.1.0 <=1.8.3": "1.8.4",
      "tmp@<0.2.7": "0.2.7",
      "undici@>=7.0.0 <7.28.0": "7.28.0",
      "ws@>=8.0.0 <8.21.0": "8.21.0"
    }
  }
}
