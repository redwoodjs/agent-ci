{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "machinen",
  "main": "src/worker.tsx",
  "compatibility_date": "2025-09-25",
  "compatibility_flags": ["nodejs_compat"],

  "observability": {
    "enabled": true
  },

  "r2_buckets": [
    {
      "binding": "MACHINEN_BUCKET",
      "bucket_name": "machinen",
      "remote": true
    }
  ],
  "ai": {
    "binding": "AI",
    "remote": true
  },

  "migrations": [
    {
      "tag": "v1",
      "new_classes": ["RealtimeDurableObject"],
      "new_sqlite_classes": ["Database"]
    },
    {
      "tag": "v2",
      "deleted_classes": []
    },
    {
      "tag": "v3",
      "new_sqlite_classes": ["CursorEventsDurableObject"]
    },
    {
      "tag": "v4",
      "new_sqlite_classes": ["GitHubRepoDurableObject"]
    },
    {
      "tag": "v5",
      "new_sqlite_classes": ["GitHubBackfillStateDO"]
    }
  ],
  "durable_objects": {
    "bindings": [
      { "name": "REALTIME", "class_name": "RealtimeDurableObject" },
      { "name": "DB", "class_name": "Database" },
      { "name": "CURSOR_EVENTS", "class_name": "CursorEventsDurableObject" },
      { "name": "GITHUB_REPO", "class_name": "GitHubRepoDurableObject" },
      { "name": "GITHUB_BACKFILL_STATE", "class_name": "GitHubBackfillStateDO" }
    ]
  },
  "queues": {
    "producers": [
      {
        "queue": "github-scheduler-queue-prod",
        "binding": "SCHEDULER_QUEUE"
      },
      {
        "queue": "github-processor-queue-prod",
        "binding": "PROCESSOR_QUEUE"
      }
    ],
    "consumers": [
      {
        "queue": "github-scheduler-queue-prod",
        "max_batch_size": 10,
        "max_batch_timeout": 30
      },
      {
        "queue": "github-processor-queue-prod",
        "max_batch_size": 100,
        "max_batch_timeout": 30,
        "dead_letter_queue": "github-processor-queue-prod-dlq",
        "max_retries": 3
      },
      {
        "queue": "github-processor-queue-prod-dlq",
        "max_batch_size": 10,
        "max_batch_timeout": 30
      }
    ]
  },
  "env": {
    "test": {
      "queues": {
        "producers": [
          {
            "queue": "github-scheduler-queue",
            "binding": "SCHEDULER_QUEUE"
          },
          {
            "queue": "github-processor-queue",
            "binding": "PROCESSOR_QUEUE"
          }
        ],
        "consumers": [
          {
            "queue": "github-scheduler-queue",
            "max_batch_size": 10,
            "max_batch_timeout": 30
          },
          {
            "queue": "github-processor-queue",
            "max_batch_size": 100,
            "max_batch_timeout": 30,
            "dead_letter_queue": "github-processor-queue-dlq",
            "max_retries": 3
          },
          {
            "queue": "github-processor-queue-dlq",
            "max_batch_size": 10,
            "max_batch_timeout": 30
          }
        ]
      }
    }
  }
}
