{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "machinen",
  "main": "src/worker.tsx",
  "compatibility_date": "2025-07-29",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "containers": [
    {
      "name": "rwsdk",
      "image": "./Dockerfile",
      "class_name": "MachinenContainer",
      "max_instances": 5
    }
  ],
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["MachinenContainer"]
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "class_name": "MachinenContainer",
        "name": "CONTAINER"
      }
    ]
  },
  "queues": {
    "producers": [
      {
        "queue": "container-boot-queue",
        "binding": "QUEUE_CONTAINER_BOOT"
      }
    ],
    "consumers": [
      {
        "queue": "container-boot-queue",
        "max_batch_size": 10,
        "max_batch_timeout": 5,
        "max_retries": 3
      }
    ]
  }
}
