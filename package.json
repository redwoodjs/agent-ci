{
  "name": "machinen",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "keywords": [],
  "author": "RedwoodJS Inc",
  "license": "FSL-1.1-MIT",
  "private": true,
  "scripts": {
    "build": "vite build",
    "dev": "NODE_ENV=${NODE_ENV:-development} vite dev",
    "dev:log": "NODE_ENV=${NODE_ENV:-development} vite dev 2>&1 | tee /tmp/machinen-dev.log",
    "dev:init": "rw-scripts dev-init",
    "preview": "vite preview",
    "worker:run": "rw-scripts worker-run",
    "clean": "npm run clean:vite",
    "clean:vite": "rm -rf ./node_modules/.vite",
    "test:contract": "node scripts/test-contract-with-dev.mjs",
    "test:contract:raw": "node --test tests/simulation-runner.contract.test.mjs",
    "test:phase-a": "node --test tests/simulation-phase-a.acceptance.test.mjs",
    "test:all": "node scripts/test-all-with-dev.mjs",
    "release": "bash -c 'set -a && [ -f .dev.vars ] && source <(grep -v \"^#\" .dev.vars | grep \"=\") && set +a; rw-scripts ensure-deploy-env && npm run clean && RWSDK_DEPLOY=1 npm run build && wrangler deploy'",
    "release:prd": "CLOUDFLARE_ENV=production pnpm release",
    "generate": "rw-scripts ensure-env && wrangler types && npm run generate:discord-types",
    "fetch:discord-openapi": "node scripts/fetch-discord-openapi.mjs",
    "generate:discord-types": "npm run fetch:discord-openapi && openapi-typescript src/app/ingestors/discord/openapi.json -o src/app/ingestors/discord/discord-api-types.ts",
    "check": "npm run generate && npm run types",
    "types": "tsc",
    "build:mcp-server": "tsx scripts/build-mcp-server.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.22.0",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@tailwindcss/vite": "^4.1.11",
    "better-auth": "^1.3.9",
    "browser-util-inspect": "^0.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.525.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-server-dom-webpack": "^19.2.0",
    "rwsdk": "1.0.0-beta.47",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.11",
    "tw-animate-css": "^1.3.6",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.934.0",
    "@cloudflare/vite-plugin": "^1.20.1",
    "@cloudflare/workers-types": "^4.20260109.0",
    "@types/node": "^22.17.1",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "esbuild": "^0.24.0",
    "openapi-typescript": "^7.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "vite": "^6.3.5",
    "wrangler": "^4.58.0",
    "ws": "^8.18.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
