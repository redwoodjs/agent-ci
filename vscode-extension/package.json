{
  "name": "machinen",
  "displayName": "Machinen",
  "description": "Shows code origin and decisions when hovering over //? in code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionDependencies": [
    "google.antigravity"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Machinen",
      "properties": {
        "machinen.overrideCursorCompletions": {
          "type": "boolean",
          "default": true,
          "description": "When true, this extension's completions will take precedence when //? pattern is detected. Note: You may need to disable 'editor.inlineSuggest.enabled' or Cursor's completions separately."
        },
        "machinen.apiUrl": {
          "type": "string",
          "default": "https://machinen.redwoodjs.workers.dev",
          "description": "The base URL for the Machinen API"
        },
        "machinen.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for authenticating with the Machinen API"
        },
        "machinen.namespace": {
          "type": "string",
          "default": "",
          "description": "Moment graph namespace to use for queries. If not set, uses the default namespace configured on the backend (MOMENT_GRAPH_NAMESPACE environment variable)."
        }
      }
    },
    "commands": [
      {
        "command": "machinen.getPrOrigin",
        "title": "Get PR Origin",
        "category": "Machinen"
      },
      {
        "command": "machinen.processMachineCallback",
        "title": "Machinen TLDR",
        "category": "Machinen"
      },
      {
        "command": "machinen.uploadAntigravityData",
        "title": "Upload Antigravity Artifacts to Machinen",
        "category": "Machinen"
      },
      {
        "command": "machinen.forceUploadAntigravityData",
        "title": "Force Upload Antigravity Artifacts to Machinen",
        "category": "Machinen"
      },
      {
        "command": "machinen.debugAntigravity",
        "title": "Debug Antigravity",
        "category": "Machinen"
      }
    ],
    "keybindings": [
      {
        "command": "machinen.processMachineCallback",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m",
        "when": "editorHasSelection"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "machinen.processMachineCallback",
          "group": "navigation",
          "when": "editorHasSelection"
        },
        {
          "command": "machinen.uploadAntigravityData",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "protobufjs": "^8.0.0",
    "snappy": "^7.3.3",
    "typescript": "^5.0.0"
  }
}
